{
  "name": "x-to-md-clipper",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wxt --browser chrome",
    "build": "wxt build --browser chrome",
    "build:loaded": "npm run build && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sync-loaded-extension.ps1",
    "zip": "wxt zip --browser chrome",
    "compile": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "wxt": "^0.20.11"
  },
  "overrides": {
    "@webext-core/fake-browser": "1.3.4"
  }
}
